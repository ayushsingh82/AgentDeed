# 0G Storage — defaults to the public 0G endpoints
NEXT_PUBLIC_OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_OG_KV_NODE_URL=https://rpc-storage-testnet-turbo.0g.ai

# 0G Compute — TEE inference broker
NEXT_PUBLIC_OG_COMPUTE_BROKER_URL=https://compute-testnet.0g.ai

# 0G Compute Router — OpenAI-compatible inference gateway.
# Base URL is optional (defaults to the public router).
NEXT_PUBLIC_OG_ROUTER_URL=https://router-api.0g.ai
# Server-side only — never exposed to the browser. Required for /playground
# chat completions; the model catalog works without it.
OG_ROUTER_API_KEY=

# --- Local fallback: Ollama ---------------------------------------------
# Set this to point /playground at a local Ollama instance instead of the
# 0G Router. Useful when you don't have a router API key yet. No key needed.
#   brew install ollama && ollama pull qwen2:0.5b && ollama serve
# Then uncomment:
# OLLAMA_BASE_URL=http://localhost:11434

# AgentDeed ERC-7857 contract address on 0G.
# Live deployment (chain 16602):
NEXT_PUBLIC_AGENT_DEED_ADDRESS=0x21cBA803EdB8676D06FAf9aCAb84611C98B7A370

# TEEOracle address — verifies TEE re-encryption proofs on transfer/clone.
# Currently deployed but not wired into AgentDeed (permissionless transfers).
NEXT_PUBLIC_TEE_ORACLE_ADDRESS=0xcF7294f6C6Ca09cae9b6832efbCffAB218e7d499
