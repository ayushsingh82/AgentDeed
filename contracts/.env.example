# 0G Galileo testnet RPC (optional — defaults to the public endpoint)
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Private key of the account that deploys the contracts.
# Fund it with testnet OG from https://faucet.0g.ai first.
DEPLOYER_PRIVATE_KEY=

# Set to "true" to wire AgentDeed -> TEEOracle on deploy.
# Leave unset on testnet so transfer/clone stay permissionless until a
# TEE signer is registered via TEEOracle.setSigner.
WIRE_ORACLE=
